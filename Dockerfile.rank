FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PORT=8080

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-ranking.txt /app/requirements-ranking.txt
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r /app/requirements-ranking.txt

COPY researcher-kb-pipeline/rank_service.py /app/rank_service.py
COPY researcher-kb-pipeline/search.py /app/search.py
COPY researcher-kb-pipeline/ranking.py /app/ranking.py
COPY researcher-kb-pipeline/db.py /app/db.py
COPY researcher-kb-pipeline/embeddings.py /app/embeddings.py
COPY researcher-kb-pipeline/pinecone_client.py /app/pinecone_client.py
COPY researcher-kb-pipeline/config.py /app/config.py

CMD ["sh", "-c", "python -m uvicorn rank_service:app --host 0.0.0.0 --port ${PORT:-8080}"]